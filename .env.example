IMAGE_PROVIDER=mock
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_BASE_URL=https://api.openai.com/v1
IMAGE_GEN_MODEL=dall-e-3
IMAGE_GEN_SIZE=1024x1024
IMAGE_GEN_QUALITY=standard
IMAGE_GEN_API_KEY=sk-your-openai-api-key
STORAGE_ROOT=storage
FRONTEND_API_BASE_URL=http://127.0.0.1:8000

# Optional Qiniu configuration. When missing, the backend uses simulated upload URLs.
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=https://your-cdn-domain.example.com
